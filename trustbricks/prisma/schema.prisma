generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  city      String   @default("")
  state     String   @default("")
  address   String   @default("")
  landmark  String   @default("")
  phone     String   @default("")
  whatsapp  String
  email     String
  hours     String   @default("Mon – Fri: 8am – 5pm")
  mapQuery  String   @default("")
  iconType  String   @default("Landmark")
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PfaRule {
  id                String   @id @default(cuid())
  name              String   @unique
  minimum_threshold Float
  leads             Lead[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Lead {
  id            String   @id @default(cuid())
  full_name     String
  phone         String
  employer_type String
  rsa_balance   Float
  years_in_work Int      @default(0)
  years_to_retire Int    @default(0)
  is_eligible   Boolean
  status        String   @default("new")
  
  branch_id     String
  branch        Branch   @relation(fields: [branch_id], references: [id])
  
  pfa_id        String
  pfa           PfaRule  @relation(fields: [pfa_id], references: [id])
  
  createdAt     DateTime @default(now())
}
